PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/blog?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional: production custom domain (for CORS if frontend is on another host)
# CLIENT_ORIGIN=https://www.example.com

# Local: API routes are under /api — e.g. POST http://localhost:5000/api/auth/register
